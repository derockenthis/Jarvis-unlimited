# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TRANSCRIPTION_MODEL=nvidia/parakeet-tdt-0.6b-v3

# Backend
JARVIS_BACKEND_HOST=127.0.0.1
JARVIS_BACKEND_PORT=8765
JARVIS_SQLITE_PATH=apps/backend/data/jarvis.sqlite
JARVIS_ALLOWED_ROOTS=
JARVIS_FULL_FILESYSTEM_ACCESS=true

# Desktop
VITE_BACKEND_URL=http://127.0.0.1:8765
